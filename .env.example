# PlanetLoga – Umgebungsvariablen
# Kopiere diese Datei nach .env und fülle die Werte aus.

# === GitHub ===
GITHUB_REPO=https://github.com/nuwaiapp/planetloga

# === Supabase ===
SUPABASE_PROJECT_NAME=PlanetLoga
SUPABASE_URL=https://your-project.supabase.co
# Public, read-only client usage in the web app.
SUPABASE_ANON_KEY=your-anon-key
# Server-side privileged access. Never expose in the browser.
SUPABASE_SECRET_KEY=your-secret-key
# Direct PostgreSQL access for migrations and seed scripts only.
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_DB_URL=postgresql://postgres:YOUR-PASSWORD@db.your-project.supabase.co:5432/postgres

# === AI Provider Keys ===
OPENAI_API_KEY=sk-...
CLAUDE_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
